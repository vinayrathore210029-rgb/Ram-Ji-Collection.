# Database Configuration
# Supported: Local PostgreSQL or cloud databases (Neon, Supabase, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ramjicollection?schema=public"

# Server Port and Secrets
PORT=5000
JWT_SECRET="super-secret-jwt-key-replace-in-production"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-key-replace-in-production"
NODE_ENV="development"

# Cloudflare R2 (S3 compatible) Image Storage
# Set to 'local' to use uploads/ directory for dev instead of Cloudflare R2
STORAGE_PROVIDER="local"
CLOUDFLARE_R2_BUCKET="ram-ji-collection-bucket"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-your-id.r2.dev"

# Razorpay Payments
RAZORPAY_KEY_ID="rzp_test_yourkeyid"
RAZORPAY_KEY_SECRET="yourkeysecret"

# Resend Email Integration
RESEND_API_KEY="re_yourapikey"
EMAIL_FROM="Ram Ji Collection <noreply@yourdomain.com>"

# Meta WhatsApp Cloud API (Optional notifications)
WHATSAPP_ACCESS_TOKEN="your_whatsapp_access_token"
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"

# Frontend Configuration (for CORS)
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"
